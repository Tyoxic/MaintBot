{
  "expo": {
    "name": "MaintBot",
    "slug": "MaintBot",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.maintbot.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "MaintBot needs camera access so you can take photos of your vehicles.",
        "NSPhotoLibraryUsageDescription": "MaintBot needs access to your photo library so you can attach photos to your vehicles.",
        "NSPhotoLibraryAddUsageDescription": "MaintBot can save photos to your library when you share a vehicle image.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyCollectedDataTypes": [],
        "NSPrivacyTracking": false,
        "NSPrivacyTrackingDomains": [],
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": ["C617.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": ["35F9.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": ["E174.1"]
          }
        ]
      }
    },
    "android": {
      "package": "com.maintbot.app",
      "allowBackup": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#2196F3"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "MaintBot needs camera access so you can take photos of your vehicles.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "MaintBot needs access to your photo library so you can attach photos to your vehicles."
        }
      ],
      "expo-web-browser",
      "./plugins/withLocalOnlyNotifications.js"
    ],
    "extra": {
      "eas": {
        "projectId": "2f7ab4d8-938f-4fb1-85f6-5d70bcbfe308"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/2f7ab4d8-938f-4fb1-85f6-5d70bcbfe308",
      "fallbackToCacheTimeout": 5000,
      "checkAutomatically": "ON_LOAD"
    }
  }
}
